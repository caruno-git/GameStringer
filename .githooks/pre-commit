#!/bin/sh
# GameStringer Pre-commit Hook - Auto Version Management

echo "🚀 GameStringer Pre-commit Hook"

# ── Guardia check-linux (anti-E0433) ───────────────────────────────
# Ogni #[tauri::command] Windows-only registrato nell'invoke_handler deve
# avere lo stub corrispondente in platform_stubs.rs, altrimenti check-linux
# fallisce in CI con E0433. Verifica statica locale (~0.5s, niente cargo).
if git diff --cached --name-only | grep -qE "src-tauri/.*\.rs$"; then
    echo "🔍 Verifica stub Linux per comandi Windows-only..."
    if command -v python >/dev/null 2>&1; then PY=python; else PY=python3; fi
    if ! "$PY" scripts/check-linux-stubs.py; then
        echo "❌ Commit bloccato: aggiungi gli stub mancanti in src-tauri/src/commands/platform_stubs.rs"
        exit 1
    fi
fi

# Controlla se ci sono modifiche nei file di versioning
if git diff --cached --name-only | grep -qE "(version\.json|package\.json)"; then
    echo "⚠️  Version files modificati, skip auto-increment"
    exit 0
fi

# Auto-increment build number solo se ci sono modifiche al codice
if git diff --cached --name-only | grep -qE "\.(ts|tsx|js|jsx|rs|toml)$"; then
    echo "📦 Incremento build number automatico..."
    
    # Increment build number
    node scripts/version-manager.js build
    
    # Aggiungi i file modificati al commit
    git add version.json
    git add package.json 2>/dev/null || true
    git add CHANGELOG.md 2>/dev/null || true
    
    echo "✅ Build number incrementato automaticamente"
else
    echo "📄 Solo modifiche non-code, skip version increment"
fi

exit 0