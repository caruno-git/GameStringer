{
  "productName": "GameStringer",
  "version": "1.8.2",
  "identifier": "com.gamestringer.app",
  "build": {
    "beforeDevCommand": "npx next dev -p 3222",
    "beforeBuildCommand": "node scripts/build-tauri-cross.js",
    "devUrl": "http://127.0.0.1:3224",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GameStringer",
        "width": 1280,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "center": true,
        "visible": true,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false
      },
      {
        "label": "ocr-overlay",
        "title": "OCR Overlay",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "url": "/ocr-overlay"
      },
      {
        "label": "chat",
        "title": "GameStringer Chat",
        "width": 380,
        "height": 620,
        "minWidth": 320,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "center": false,
        "visible": false,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "url": "/chat-popup"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://steamcdn-a.akamaihd.net https://cdn.akamai.steamstatic.com https://shared.akamai.steamstatic.com https://cdn.steamgriddb.com https://cdn2.steamgriddb.com https://media.steampowered.com https://cdn.cloudflare.steamstatic.com https://store.steampowered.com https://avatars.githubusercontent.com; connect-src 'self' https://api.openai.com https://api.anthropic.com https://generativelanguage.googleapis.com https://api.deepseek.com https://api.mistral.ai https://openrouter.ai https://api.github.com https://api.nexusmods.com https://api.steampowered.com https://api.rawg.io https://api.igdb.com https://howlongtobeat.com https://www.steamgriddb.com http://127.0.0.1:* http://localhost:*; font-src 'self' data:; media-src 'self' blob:",
      "capabilities": [
        "default",
        "app-events"
      ]
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": [],
      "signingIdentity": null
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1"
        ]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBM0FCODIxNkRCQTA3N0UKUldSK0I3cHRJYmc2U3U4NDg4YlkrNTFLMmdLckRGeFRrak5WZmg2R2xGeFo0dHdad3BpTFJnWUMK",
      "endpoints": [
        "https://github.com/rouges78/GameStringer/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}